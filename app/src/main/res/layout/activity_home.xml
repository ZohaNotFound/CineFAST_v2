<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg"
    android:padding="6dp">

    <!-- app name logo -->
    <View
        android:layout_width="match_parent"
        android:layout_height="25dp"/>
    <ImageView
        android:id="@+id/appNameImage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/name"
        android:layout_marginStart="3dp"
        android:layout_marginTop="3dp" />

    <!-- date selector -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Date"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button
                android:id="@+id/btnToday"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today"
                android:textSize="12sp"
                android:background="@color/white"
                style="@style/Widget.AppCompat.Button.Borderless" />
            <Button
                android:id="@+id/btnTomorrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tomorrow"
                android:textSize="12sp"
                android:background="@color/white"
                style="@style/Widget.AppCompat.Button.Borderless" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Now Showing"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <!-- today's movies -->
    <LinearLayout
        android:id="@+id/todayMovies"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- The Dark Knight card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:background="@color/cardview_shadow_end_color"
            app:cardCornerRadius="6dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="4dp">
                <ImageView
                    android:id="@+id/imgDarkKnight"
                    android:layout_width="60dp"
                    android:layout_height="80dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/dark_knight" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="6dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/tvDarkKnightTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="The Dark Knight"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end" />
                    <TextView
                        android:id="@+id/tvDarkKnightDetails"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Action / 152 min"
                        android:textSize="10sp"
                        android:layout_marginTop="1dp" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="2dp">
                        <Button
                            android:id="@+id/btnDarkKnightTrailer"
                            android:layout_width="wrap_content"
                            android:layout_height="20dp"
                            android:text="Trailer"
                            android:textSize="8sp"
                            android:padding="2dp"
                            style="@style/Widget.AppCompat.Button.Borderless" />
                        <Button
                            android:id="@+id/btnDarkKnightBook"
                            android:layout_width="wrap_content"
                            android:layout_height="20dp"
                            android:text="Book"
                            android:textSize="8sp"
                            android:padding="2dp"
                            style="@style/Widget.AppCompat.Button.Borderless" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Inception card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            app:cardCornerRadius="6dp"
            app:cardElevation="2dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="4dp">
                <ImageView
                    android:id="@+id/imgInception"
                    android:layout_width="60dp"
                    android:layout_height="80dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/inception" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="6dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/tvInceptionTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Inception"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end" />
                    <TextView
                        android:id="@+id/tvInceptionDetails"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sci-Fi / 148 min"
                        android:textSize="10sp"
                        android:layout_marginTop="1dp" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="2dp">
                        <Button
                            android:id="@+id/btnInceptionTrailer"
                            android:layout_width="wrap_content"
                            android:layout_height="20dp"
                            android:text="Trailer"
                            android:textSize="8sp"
                            android:padding="2dp"
                            style="@style/Widget.AppCompat.Button.Borderless" />
                        <Button
                            android:id="@+id/btnInceptionBook"
                            android:layout_width="wrap_content"
                            android:layout_height="20dp"
                            android:text="Book"
                            android:textSize="8sp"
                            android:padding="2dp"
                            style="@style/Widget.AppCompat.Button.Borderless" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Interstellar card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            app:cardCornerRadius="6dp"
            app:cardElevation="2dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="4dp">
                <ImageView
                    android:id="@+id/imgInterstellar"
                    android:layout_width="60dp"
                    android:layout_height="80dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/interstellar" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="6dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/tvInterstellarTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Interstellar"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end" />
                    <TextView
                        android:id="@+id/tvInterstellarDetails"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sci-Fi / 169 min"
                        android:textSize="10sp"
                        android:layout_marginTop="1dp" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="2dp">
                        <Button
                            android:id="@+id/btnInterstellarTrailer"
                            android:layout_width="wrap_content"
                            android:layout_height="20dp"
                            android:text="Trailer"
                            android:textSize="12sp"
                            android:padding="6dp"
                            style="@style/Widget.AppCompat.Button.Borderless" />
                        <Button
                            android:id="@+id/btnInterstellarBook"
                            android:layout_width="wrap_content"
                            android:layout_height="20dp"
                            android:text="Book"
                            android:textSize="12sp"
                            android:padding="6dp"
                            style="@style/Widget.AppCompat.Button.Borderless" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Shawshank card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            app:cardCornerRadius="6dp"
            app:cardElevation="2dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="4dp">
                <ImageView
                    android:id="@+id/imgShawshank"
                    android:layout_width="60dp"
                    android:layout_height="80dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/shawshank" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="6dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/tvShawshankTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="The Shawshank Redemption"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end" />
                    <TextView
                        android:id="@+id/tvShawshankDetails"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Drama / 142 min"
                        android:textSize="10sp"
                        android:layout_marginTop="1dp" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="2dp">
                        <Button
                            android:id="@+id/btnShawshankTrailer"
                            android:layout_width="wrap_content"
                            android:layout_height="20dp"
                            android:text="Trailer"
                            android:textSize="8sp"
                            android:padding="2dp"
                            style="@style/Widget.AppCompat.Button.Borderless" />
                        <Button
                            android:id="@+id/btnShawshankBook"
                            android:layout_width="wrap_content"
                            android:layout_height="20dp"
                            android:text="Book"
                            android:textSize="8sp"
                            android:padding="2dp"
                            style="@style/Widget.AppCompat.Button.Borderless" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- tomorrow's movies (hidden by default) -->
    <LinearLayout
        android:id="@+id/tomorrowMovies"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Doremon card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            app:cardCornerRadius="6dp"
            app:cardElevation="2dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="4dp">
                <ImageView
                    android:id="@+id/imgDoremon"
                    android:layout_width="60dp"
                    android:layout_height="80dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/doremon" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="6dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/tvDoremonTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Doremon Adventure"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end" />
                    <TextView
                        android:id="@+id/tvDoremonDetails"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Animation / 90 min"
                        android:textSize="10sp"
                        android:layout_marginTop="1dp" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="2dp">
                        <Button
                            android:id="@+id/btnDoremonTrailer"
                            android:layout_width="wrap_content"
                            android:layout_height="20dp"
                            android:text="Trailer"
                            android:textSize="8sp"
                            android:padding="2dp"
                            style="@style/Widget.AppCompat.Button.Borderless" />
                        <Button
                            android:id="@+id/btnDoremonBook"
                            android:layout_width="wrap_content"
                            android:layout_height="20dp"
                            android:text="Book"
                            android:textSize="8sp"
                            android:padding="2dp"
                            style="@style/Widget.AppCompat.Button.Borderless" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Dora card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            app:cardCornerRadius="6dp"
            app:cardElevation="2dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="4dp">
                <ImageView
                    android:id="@+id/imgDora"
                    android:layout_width="60dp"
                    android:layout_height="80dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/dora" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="6dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/tvDoraTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dora Explorer"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end" />
                    <TextView
                        android:id="@+id/tvDoraDetails"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Adventure / 85 min"
                        android:textSize="10sp"
                        android:layout_marginTop="1dp" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="2dp">
                        <Button
                            android:id="@+id/btnDoraTrailer"
                            android:layout_width="wrap_content"
                            android:layout_height="20dp"
                            android:text="Trailer"
                            android:textSize="8sp"
                            android:padding="2dp"
                            style="@style/Widget.AppCompat.Button.Borderless" />
                        <Button
                            android:id="@+id/btnDoraBook"
                            android:layout_width="wrap_content"
                            android:layout_height="20dp"
                            android:text="Book"
                            android:textSize="8sp"
                            android:padding="2dp"
                            style="@style/Widget.AppCompat.Button.Borderless" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Dark Knight (tomorrow) card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            app:cardCornerRadius="6dp"
            app:cardElevation="2dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="4dp">
                <ImageView
                    android:id="@+id/imgDarkKnightTomorrow"
                    android:layout_width="60dp"
                    android:layout_height="80dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/dark_knight" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="6dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/tvDarkKnightTitleTomorrow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="The Dark Knight"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end" />
                    <TextView
                        android:id="@+id/tvDarkKnightDetailsTomorrow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Action / 152 min"
                        android:textSize="10sp"
                        android:layout_marginTop="1dp" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="2dp">
                        <Button
                            android:id="@+id/btnDarkKnightTrailerTomorrow"
                            android:layout_width="wrap_content"
                            android:layout_height="20dp"
                            android:text="Trailer"
                            android:textSize="8sp"
                            android:padding="2dp"
                            style="@style/Widget.AppCompat.Button.Borderless" />
                        <Button
                            android:id="@+id/btnDarkKnightBookTomorrow"
                            android:layout_width="wrap_content"
                            android:layout_height="20dp"
                            android:text="Book"
                            android:textSize="8sp"
                            android:padding="2dp"
                            style="@style/Widget.AppCompat.Button.Borderless" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Inception (tomorrow) card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            app:cardCornerRadius="6dp"
            app:cardElevation="2dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="4dp">
                <ImageView
                    android:id="@+id/imgInceptionTomorrow"
                    android:layout_width="60dp"
                    android:layout_height="80dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/inception" />
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="6dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/tvInceptionTitleTomorrow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Inception"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end" />
                    <TextView
                        android:id="@+id/tvInceptionDetailsTomorrow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sci-Fi / 148 min"
                        android:textSize="10sp"
                        android:layout_marginTop="1dp" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="2dp">
                        <Button
                            android:id="@+id/btnInceptionTrailerTomorrow"
                            android:layout_width="wrap_content"
                            android:layout_height="20dp"
                            android:text="Trailer"
                            android:textSize="8sp"
                            android:padding="2dp"
                            style="@style/Widget.AppCompat.Button.Borderless" />
                        <Button
                            android:id="@+id/btnInceptionBookTomorrow"
                            android:layout_width="wrap_content"
                            android:layout_height="20dp"
                            android:text="Book"
                            android:textSize="8sp"
                            android:padding="2dp"
                            style="@style/Widget.AppCompat.Button.Borderless" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

</LinearLayout>